# Copy to .env and fill in. NEVER commit the real .env.
MONGO_URL="your-mongodb-atlas-connection-string"
DB_NAME="theaarshalabel"
CORS_ORIGINS="https://theaarshalabel.com"
FRONTEND_URL="https://theaarshalabel.com"

# Razorpay (use LIVE keys in production)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Email notifications
STORE_NAME="The Aarsha's Label"
OWNER_EMAIL=""

# Mailgun (verify your own domain for production)
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_BASE_URL="https://api.mailgun.net"

# SMTP (alternative to Mailgun API; e.g. Mailgun SMTP)
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="The Aarsha's Label <orders@theaarshalabel.com>"

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
OWNER_WHATSAPP=""
